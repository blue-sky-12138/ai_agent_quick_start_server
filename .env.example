# 您从 ZEGO 控制台（https://console.zego.im/）获取的AppID和ServerSecret
# AppID and ServerSecret obtained by you from ZEGOCLOUD console（https://console.zegocloud.com/）
NEXT_PUBLIC_ZEGO_APP_ID=
ZEGO_SERVER_SECRET=

# 您从LLM服务商获取的LLM API Key、Base URL和模型
# 在接入测试期间（联系 ZEGO 技术支持开通 AI Agent 服务 2 周内），有部分模型可直接使用，请参考：https://doc-zh.zego.im/aiagent-server/api-reference/common-parameter-description#llm
# 接入测试期间，以下配置可直接使用，无需修改
# LLM API Key, Base URL and models obtained by you from the LLM service provider
# During the access test period (within 2 weeks after contacting ZEGOCLOUD technical support to activate the AI Agent service), some models can be used directly. Please refer to: https://www.zegocloud.com/docs/aiagent-server/api-reference/common-parameter-description#llm
# During the access test period, the following configurations can be used directly without modification
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
LLM_API_KEY=zego_test
LLM_MODEL=doubao-1-5-lite-32k-250115
# 智能体提示词（不配置时会使用默认的提示词）
# LLM_SYSTEM_PROMPT="回答问题要求：你在做角色扮演，请按照人设要求与用户对话，直接输出回答，回答时以句号为维度，单次回答最长不要超过3句，不能超过100字。\n角色：李悦然\n绰号：李老师"
# 是否在请求自定义 LLM 时携带 agent_info（建议开启，便于在 /chat/completions 中按实例做业务逻辑）
LLM_ADD_AGENT_INFO=true
# 透传到自定义 LLM 的扩展字段（JSON 字符串）
# LLM_AGENT_EXTRA_INFO='{"biz":"demo"}'

# 如需使用本服务的 LLM 代理，可二选一：
# 方式一：保留 LLM_BASE_URL，填代理地址，例如 LLM_BASE_URL=https://your-domain/chat/completions
# 方式二：仅使用 LLM_PROXY 配置（不填 LLM_BASE_URL/LLM_API_KEY/LLM_MODEL），见下方

# 仅使用 LLM 代理时：ZEGO 调用的地址（必须公网可达，本地调试用 ngrok）
# 示例（ngrok）：LLM_PROXY_PUBLIC_URL=https://nonexceptional-brigette-comfortingly.ngrok-free.dev/chat/completions
# LLM_PROXY_PUBLIC_URL=https://your-ngrok-subdomain.ngrok-free.dev/chat/completions

# LLM 代理上游配置（必填：UPSTREAM_URL、UPSTREAM_API_KEY）
LLM_PROXY_UPSTREAM_URL=https://k2.kkkdisplay.com:5678/api/v1/chat/completions
LLM_PROXY_UPSTREAM_API_KEY=sk-xxx
LLM_PROXY_UPSTREAM_MODEL=anthropic/claude-sonnet-4.6
# 代理使用的 system prompt（不填则使用内置「加密货币交易所教学帮助人员」人设）
# LLM_PROXY_SYSTEM_PROMPT=
# 代理入站鉴权（可选，ZEGO 请求时携带的 ApiKey 会传到此）
# LLM_PROXY_AUTH_TOKEN=
# OPENROUTER_SITE_URL=https://your-domain
# OPENROUTER_APP_NAME=ai-agent-quick-start-server

# 知识库 RAG：请求中解析出的 user / user_id / agent_info.user_id 必须命中下方白名单，且 RAG_KB_MODE 非 off、已配 URL 才启用
# RAG_KB_ALLOWED_USER_IDS=user_a,user_b   # 逗号分隔（可用中文逗号），未配置或为空则不对任何用户启用知识库
# RAG_KB_MODE=off           # 关闭（默认）
# RAG_KB_MODE=proxy         # 先非流式请求知识库，将返回文本注入最后一条 user（多段 text），再请求 LLM_PROXY 上游
# RAG_KB_MODE=tool          # 仍走 LLM_PROXY 上游，由模型 function calling 调用知识库接口拉取片段后再答
# RAG_KB_COMPLETIONS_URL=http://127.0.0.1/chat/api/<应用或会话ID>/chat/completions
# RAG_KB_API_KEY=           # 对应 curl 的 Authorization: Bearer
# RAG_KB_CSRF_TOKEN=        # 若服务端要求 X-CSRFTOKEN（可选）
# RAG_KB_RE_CHAT=false      # 请求知识库时的 re_chat，默认 false
# RAG_KB_MAX_TOOL_ROUNDS=4  # tool 模式下工具轮次上限（1～8，默认 4）
# RAG_KB_INJECT_BLOCK_LABEL=【知识库检索结果】  # 注入到 user 的第一段 text 标题行
# RAG_KB_MAX_INJECT_CHARS=16000             # 注入正文最大字符数（超出截断）
# RAG_KB_SYSTEM_HINT_APPEND=                # 追加到 system 的说明；不设则用默认；设为空字符串则不追加
# RAG_KB_STREAM=true                        # MaxKB 等：用 stream:true + SSE 累积正文（默认）；false 则非流式 JSON
# RAG_KB_LOG=verbose                        # 打印知识库返回全文（截断见下）；设为 false 仅打印耗时与字数
# RAG_KB_LOG_MAX_CHARS=8000                 # 全文日志单条最多字符（超出加「全文共 n 字」）

# 这里以字节跳动的TTS为例，您从字节跳动获取的TTS API Key、Token、Cluster和Voice Type
# 在接入测试期间（ 联系 ZEGO 技术支持开通 AI Agent 服务 2 周内）appid和token都可以直接填 zego_test 就可使用 tts（文本转语音） 服务。
# 接入测试期间，以下配置可直接使用，无需修改
# Taking ByteDance's TTS as an example, during the access test period (within 2 weeks after contacting ZEGOCLOUD technical support to activate the AI Agent service)
# both the appid and token can be directly filled with "zego_test" to use the TTS (Text-to-Speech) service.
# The following configurations can be used directly without modification during the access test period:
TTS_BYTEDANCE_APP_ID=zego_test
TTS_BYTEDANCE_TOKEN=zego_test
TTS_BYTEDANCE_CLUSTER=volcano_tts
TTS_BYTEDANCE_VOICE_TYPE=zh_female_wanwanxiaohe_moon_bigtts

# Minimax TTS：若已配置 MySQL 且存在表 iwala_aiagent_config（见 sql/iwala_aiagent_config.sql），
# 优先读 config_key=tts_minimax（可用 TTS_MINIMAX_CONFIG_KEY 覆盖）的 config_value（JSON）；失败或无有效 JSON 时回退下列变量
# TTS_MINIMAX_CONFIG_KEY=tts_minimax
TTS_MINIMAX_API_KEY=zego_test
# TTS_MINIMAX_GROUP_ID=
TTS_MINIMAX_MODEL=speech-02-turbo-preview
TTS_MINIMAX_VOICE_ID=female-shaonv

# LLM 输入输出入库（MySQL），不配置则跳过写入；DB 操作异步执行，不阻塞接口
# 上传图片接口依赖同一套变量，图片表建在 DB_DATABASE 指定的库中（例如 szb02）
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_DATABASE=

# 上传成功后返回的 image_url 公网前缀（不填则使用当前请求的 Origin）
# PUBLIC_BASE_URL=https://your-domain.com

# 创建智能体时的高级配置，可配置打断模式等，请参考：https://doc-zh.zego.im/aiagent-server/api-reference/agent-instance-management/create-agent-instance
# ADVANCED_CONFIG='{"InterruptMode":1}'
